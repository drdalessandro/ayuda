# Backend Configuration
EXPO_PUBLIC_BACKEND_TYPE=medplum

# FHIR-native healthcare backend with Medplum
EXPO_PUBLIC_MEDPLUM_BASE_URL=
EXPO_PUBLIC_MEDPLUM_CLIENT_ID=
EXPO_PUBLIC_MEDPLUM_PROJECT_ID=

# Google Sign-In (OAuth 2.0)
# Obtener en: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs
# También configurar en Medplum: Admin → Project → Edit → Google Auth Client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# iOS: el "Reversed Client ID" de la credencial iOS (formato: com.googleusercontent.apps.xxx)
EXPO_PUBLIC_GOOGLE_IOS_REVERSED_CLIENT_ID=

# reCAPTCHA v3 (solo si está habilitado en Medplum)
# Obtener en: https://www.google.com/recaptcha/admin → Crear sitio → Tipo: reCAPTCHA v3
# Si no está habilitado en Medplum: dejar en blanco (no se mostrará el modal)
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=
